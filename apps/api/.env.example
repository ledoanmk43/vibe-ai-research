# ─── Application ─────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# ─── Database ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=laundry_user
DB_PASSWORD=laundry_secret
DB_NAME=laundry_crm
DB_SYNCHRONIZE=true
DB_LOGGING=false

# ─── Firebase Admin ──────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_REAL_KEY\n-----END PRIVATE KEY-----\n"

# ─── CORS ────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
